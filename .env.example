# Supabase project URL
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Supabase public anon key (safe for client-side usage)
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY"

# Public app origin used inside generated QR codes
VITE_APP_ORIGIN="https://id-verifier-black.vercel.app"

# Server-only key for /api/verify-token (set in Vercel project env vars only)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVER_ONLY_SERVICE_ROLE_KEY"
